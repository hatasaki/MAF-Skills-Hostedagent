# ====== Microsoft Foundry プロジェクト ======
# 例: https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=

# オーケストレータが使う LLM のモデルデプロイ名 (Foundry プロジェクトに作成済みのものを指定)
# 例: gpt-5.2
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# ====== 既存 Foundry エージェント (Prompt Agent) ======
# Microsoft 技術専門家エージェント (Microsoft Learn ベース)
MS_LEARN_AGENT_NAME=
MS_LEARN_AGENT_VERSION=1

# Web 検索エージェント (Bing Grounding 等)
WEB_SEARCH_AGENT_NAME=
WEB_SEARCH_AGENT_VERSION=1
